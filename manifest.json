{
	"manifest_version": 2,
	"name": "Group Tabs by Collection",
	"version": "1.1.1",
	"description": "Groups open reader/snapshot tabs by Zotero collection. Suggests resolutions for items in multiple collections.",
	"icons": {
		"48": "content/icons/favicon.svg",
		"96": "content/icons/favicon.svg"
	},
	"applications": {
		"zotero": {
			"id": "group-tabs-by-collection@example.com",
			"update_url": "https://raw.githubusercontent.com/ppavlidis/group-tabs-by-collection/main/updates.json",
			"strict_min_version": "7.0.0",
			"strict_max_version": "9.*"
		}
	}
}
